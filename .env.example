# Environment variables for Docker Compose
# Copy this file to .env and fill in your values

# Docker Registry (default: ghcr.io)
REGISTRY=ghcr.io

# Image Owner (your GitHub username)
IMAGE_OWNER=szw321127

# Docker Image Tag
IMAGE_TAG=latest

# Public domain used by Caddy for HTTPS certificates
APP_DOMAIN=mira.autos

# Temporary HTTP IP fallback for pre-备案 checks
APP_IP=47.115.149.71

# Database Password (PostgreSQL)
DB_PASSWORD=your_strong_database_password_here
DATABASE_URL=postgresql://rednote:your_strong_database_password_here@localhost:5432/rednote?schema=public
REDIS_URL=redis://localhost:6379

# Mira model and search keys are stored in PostgreSQL.
# Log in to /admin and configure model Base URL, model name,
# model API key, and Tavily search key there.
AGENT_MAX_STEPS=8

# Local backend development
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_AGENT_BASE_URL=http://localhost:3001

# Mira admin console
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Session Secret (change in production)
SESSION_SECRET=rednote-production-session-secret-key-change-this
