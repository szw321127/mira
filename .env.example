# Environment variables for Docker Compose
# Copy this file to .env and fill in your values

# Docker Registry (default: ghcr.io)
REGISTRY=ghcr.io

# Image Owner (your GitHub username)
IMAGE_OWNER=szw321127

# Docker Image Tag
IMAGE_TAG=latest

# Database Password (PostgreSQL)
DB_PASSWORD=your_strong_database_password_here

# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret (change in production)
JWT_SECRET=rednote-production-jwt-secret-key-change-this

# Local backend development
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
XHS_CONNECTOR_BASE_URL=http://localhost:8800
XHS_CONNECTOR_API_KEY=rednote-local-xhs-connector-key
XHS_AUTH_SECRET=rednote-local-xhs-auth-secret-change-me
SPIDER_XHS_PATH=/absolute/path/to/Spider_XHS

# JWT Refresh Secret (change in production)
JWT_REFRESH_SECRET=rednote-production-jwt-refresh-secret-key-change-this

# Session Secret (change in production)
SESSION_SECRET=rednote-production-session-secret-key-change-this
