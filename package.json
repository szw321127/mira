{
  "name": "rednote-workspace",
  "version": "0.0.0",
  "description": "RedNote TypeScript monorepo",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.7.0"
  },
  "scripts": {
    "dev": "concurrently -n \"connector,backend,web,admin\" -c \"bgCyan.bold,bgBlue.bold,bgMagenta.bold,bgGreen.bold\" \"pnpm dev:connector\" \"pnpm dev:backend\" \"pnpm dev:frontend\" \"pnpm dev:admin\"",
    "dev:agent": "pnpm --filter @rednote/agent dev",
    "dev:backend": "pnpm --filter @rednote/backend start:dev",
    "dev:connector": "pnpm --filter @rednote/xhs-connector dev",
    "dev:frontend": "pnpm --filter @rednote/web-frontend dev",
    "dev:web": "pnpm --filter @rednote/web-frontend dev",
    "dev:admin": "pnpm --filter @rednote/admin-frontend dev",
    "test": "pnpm -r --if-present test",
    "test:agent": "pnpm --filter @rednote/agent test",
    "test:backend": "pnpm --filter @rednote/backend test",
    "test:frontend": "pnpm --filter @rednote/web-frontend test",
    "test:web": "pnpm --filter @rednote/web-frontend test",
    "test:admin": "pnpm --filter @rednote/admin-frontend test",
    "test:connector": "pnpm --filter @rednote/xhs-connector test",
    "build": "pnpm -r --if-present build",
    "build:agent": "pnpm --filter @rednote/agent build",
    "build:backend": "pnpm --filter @rednote/backend build",
    "build:frontend": "pnpm --filter @rednote/web-frontend build",
    "build:web": "pnpm --filter @rednote/web-frontend build",
    "build:admin": "pnpm --filter @rednote/admin-frontend build"
  },
  "keywords": [
    "rednote",
    "ai",
    "nestjs",
    "react",
    "typescript",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
