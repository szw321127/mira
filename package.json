{
  "name": "rednote-workspace",
  "version": "0.0.0",
  "description": "RedNote TypeScript monorepo",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.7.0"
  },
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"bgBlue.bold,bgMagenta.bold\" \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "pnpm --filter @rednote/backend start:dev",
    "dev:frontend": "pnpm --filter @rednote/web-frontend dev",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "build:backend": "pnpm --filter @rednote/backend build",
    "build:frontend": "pnpm --filter @rednote/web-frontend build",
    "build:agent": "pnpm --filter @rednote/agent build"
  },
  "keywords": [
    "rednote",
    "ai",
    "nestjs",
    "react",
    "typescript",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
