{
  "name": "@rednote/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @rednote/agent build",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "pnpm --filter @rednote/backend build",
    "start": "node dist/main.js",
    "prestart:dev": "pnpm --filter @rednote/agent build",
    "start:dev": "node --loader ts-node/esm src/main.ts",
    "pretest": "pnpm --filter @rednote/agent build",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@rednote/agent": "workspace:*",
    "ai": "^6.0.196",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.18.0",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
