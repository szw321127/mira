{
  "name": "@rednote/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm --filter @rednote/agent build && pnpm prisma:generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "pnpm prisma:generate && DATABASE_URL=\"file:$PWD/prisma/dev.db\" prisma migrate deploy && DATABASE_URL=\"file:$PWD/prisma/dev.db\" node --conditions=development --watch --watch-path=src --watch-path=../agent/src -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "pnpm prisma:generate && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:ensure-sqlite": "node scripts/ensure-sqlite.cjs",
    "prisma:generate": "pnpm prisma:ensure-sqlite && DATABASE_URL=\"file:./dev.db\" prisma generate",
    "prisma:migrate": "pnpm prisma:ensure-sqlite && DATABASE_URL=\"file:./dev.db\" prisma migrate dev",
    "prisma:migrate:deploy": "pnpm prisma:ensure-sqlite && DATABASE_URL=\"file:./dev.db\" prisma migrate deploy",
    "prisma:push": "pnpm prisma:ensure-sqlite && DATABASE_URL=\"file:./dev.db\" prisma db push",
    "prisma:studio": "prisma studio",
    "test": "pnpm --filter @rednote/agent build && pnpm prisma:generate && jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "pnpm --filter @rednote/agent build && pnpm prisma:generate && jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.19.0",
    "@rednote/agent": "workspace:^",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "google-auth-library": "^10.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.19.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
