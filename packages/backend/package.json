{
  "name": "@rednote/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @rednote/agent build && pnpm prisma:generate",
    "build": "tsc -p tsconfig.build.json",
    "prestart": "pnpm --filter @rednote/backend build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "prestart:dev": "pnpm --filter @rednote/agent build",
    "start:dev": "node --loader ts-node/esm src/main.ts",
    "pretest": "pnpm --filter @rednote/agent build",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rednote/agent": "workspace:*",
    "ai": "^6.0.196",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.14.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.18.0",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
