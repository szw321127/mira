generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  account      String   @unique
  displayName  String
  passwordHash String?
  authProvider String   @default("password")
  googleSub    String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations Conversation[]
  xhsAuthorizations XhsAuthorization[]
}

model Conversation {
  id                String    @id @default(cuid())
  userId            String
  title             String
  topic             String
  selectedOutlineId String?
  statusMessage     String?
  lastOpenedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlineBatches OutlineBatch[]
  postDrafts     PostDraft[]
  researchRuns   XhsResearchRun[]
  savedDrafts    SavedDraft[]
  snapshots      ConversationSnapshot[]
  xhsReferences  XhsReference[]

  @@index([userId, updatedAt])
}

model OutlineBatch {
  id             String   @id @default(cuid())
  conversationId String
  batchNo        Int
  prompt         String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  outlines     Outline[]

  @@unique([conversationId, batchNo])
}

model Outline {
  id        String   @id @default(cuid())
  batchId   String
  tone      String
  label     String
  title     String
  hook      String
  points    String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch      OutlineBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  postDrafts PostDraft[]

  @@index([batchId, position])
}

model PostDraft {
  id               String    @id @default(cuid())
  conversationId   String
  outlineId        String?
  title            String
  coverLine        String
  caption          String
  imagePrompt      String
  imageUrl         String?
  imageStatus      String    @default("idle")
  imageProvider    String?
  imageError       String?
  imageGeneratedAt DateTime?
  sections         String
  tags             String
  stale            Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  outline      Outline?     @relation(fields: [outlineId], references: [id], onDelete: SetNull)
  savedDrafts  SavedDraft[]

  @@index([conversationId, updatedAt])
}

model SavedDraft {
  id             String   @id @default(cuid())
  conversationId String
  postDraftId    String?
  snapshot       String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  postDraft    PostDraft?   @relation(fields: [postDraftId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}

model ConversationSnapshot {
  id             String   @id @default(cuid())
  conversationId String
  snapshot       String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model XhsReference {
  id               String   @id @default(cuid())
  conversationId   String
  kind             String
  providerType     String
  providerEndpoint String?
  sourceId         String
  sourceUrl        String?
  title            String
  imported         String
  analysis         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, kind, sourceId])
  @@index([conversationId, createdAt])
}

model XhsResearchRun {
  id               String   @id @default(cuid())
  conversationId   String
  idea             String
  mode             String
  providerType     String
  providerEndpoint String?
  keywords         String
  sampleCount      Int
  samples          String
  analysis         String
  summary          String
  status           String
  errorMessage     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model XhsAuthorization {
  id              String   @id @default(cuid())
  userId          String
  platform        String   @default("xhs")
  subType         String   @default("pc")
  accountId       String?
  accountName     String?
  avatarUrl       String?
  cookieEncrypted String
  status          String   @default("active")
  lastValidatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
}

model AdminModelConfig {
  id              String   @id @default(cuid())
  type            String   @unique
  baseUrl         String
  modelName       String
  apiKeyEncrypted String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminUser {
  id           String    @id @default(cuid())
  account      String    @unique
  displayName  String
  passwordHash String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AdminModelApiKey {
  id              String   @id @default(cuid())
  type            String
  name            String
  apiKeyEncrypted String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type, enabled, createdAt])
}

model AdminContentProviderConfig {
  id                 String   @id @default(cuid())
  type               String   @unique
  name               String
  baseUrl            String
  enabled            Boolean  @default(false)
  rateLimitPerMinute Int?
  complianceNote     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AdminContentProviderApiKey {
  id              String   @id @default(cuid())
  type            String
  name            String
  apiKeyEncrypted String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type, enabled, createdAt])
}

model AdminProject {
  id                  String   @id @default(cuid())
  key                 String   @unique
  name                String
  owner               String
  status              String
  priority            String
  budget              String
  dueDate             String
  progress            Int      @default(0)
  team                String
  riskReason          String?
  riskSeverity        String?
  riskLatestUpdate    String?
  riskNextAction      String?
  riskEscalationOwner String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tasks AdminTask[]

  @@index([status, updatedAt])
}

model AdminTask {
  id        String   @id @default(cuid())
  key       String   @unique
  projectId String?
  name      String
  assignee  String
  dueDate   String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project AdminProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, updatedAt])
  @@index([status, updatedAt])
}

model AdminNotification {
  id          String   @id @default(cuid())
  title       String
  description String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetKey  String
  actor      String
  metadata   String
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetKey, createdAt])
}
